{
    "preset": "laravel",
    "rules": {
        "declare_strict_types": true,
        "fully_qualified_strict_types": true,
        "no_unused_imports": true,
        "no_useless_else": true,
        "no_useless_return": true,
        "ordered_imports": {
            "sort_algorithm": "alpha"
        },
        "single_quote": true,
        "trailing_comma_in_multiline": {
            "elements": ["arrays"]
        },
        "visibility_required": {
            "elements": ["property", "method", "const"]
        }
    }
}
