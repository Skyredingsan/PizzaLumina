APP_NAME=PizzaLumina
APP_ENV=local
APP_KEY=placekeyrhere
APP_DEBUG=true
APP_URL="http://localhost:${NGINX_PORT}"

APP_LOCALE=ru
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- БД: креды берём из корневого .env (один источник истины) ---
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE="${POSTGRES_DB}"
DB_USERNAME="${POSTGRES_USER}"
DB_PASSWORD="${POSTGRES_PASSWORD}"

# --- Тестовая БД (создаётся вручную: см. README) ---
DB_TEST_DATABASE=pizzalumina_test

# --- Redis ---
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- RabbitMQ (для очередей) ---
QUEUE_CONNECTION=sync
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/
RABBITMQ_USER="${RABBITMQ_USER}"
RABBITMQ_PASSWORD="${RABBITMQ_PASSWORD}"

# --- Сессии и кеш ---
SESSION_DRIVER=redis
CACHE_STORE=redis

# --- Тесты ---
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# --- Почта (заглушка — пишет в storage/logs/laravel.log) ---
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@pizzalumina.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- JWT (для этапа 4: авторизация) ---
# Сгенерировать: php artisan jwt:secret
JWT_SECRET=
JWT_TTL=60
JWT_REFRESH_TTL=20160
JWT_SHOW_BLACKLIST_EXCEPTION=true
